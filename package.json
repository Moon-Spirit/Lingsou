{
  "name": "lingsou",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "description": "A search engine project",
  "scripts": {
    "dev:meili": "bash scripts/start-meili.sh",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:web": "npm --prefix web run dev",
    "dev:crawl": "tsx scripts/crawl.ts",
    "dev": "concurrently -k -n meili,api,web -c blue,green,magenta \"npm:dev:meili\" \"npm:dev:api\" \"npm:dev:web\"",
    "start": "node dist/api/server.js",
    "build": "tsc && npm --prefix web run build",
    "crawl": "tsx scripts/crawl.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --exclude 'tests/e2e/**'",
    "test:e2e": "playwright test",
    "test:e2e:setup": "playwright install",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "web:install": "npm --prefix web install",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build"
  },
  "dependencies": {
    "fastify": "^5.3.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "meilisearch": "^0.45.0",
    "nodejieba": "^2.6.0",
    "cheerio": "^1.0.0",
    "undici": "^7.0.0",
    "p-limit": "^6.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "dotenv": "^16.4.0",
    "zod": "^3.24.0",
    "robots-parser": "^3.0.0",
    "iconv-lite": "^0.6.3",
    "jschardet": "^3.1.0",
    "concurrently": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.0.0",
    "@types/node": "^22.0.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "playwright": "^1.50.0",
    "@playwright/test": "^1.50.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "prettier": "^3.4.0",
    "vite": "^6.0.0",
    "@types/cheerio": "^0.22.0",
    "globals": "^15.0.0"
  }
}
