MEILI_HOST=http://localhost:7700
MEILI_KEY=lingsou-dev-key
MEILI_INDEX=lingsou_pages
CRAWL_MAX_PAGES=50
CRAWL_DELAY_MS=1500
CRAWL_USER_AGENT=LingsouBot/0.1 (+https://github.com/Moon-Spirit/Lingsou)
LOG_LEVEL=info
PORT=3001

# --- SERP fallback layer (opt-in) -----------------------------------------
# When set to 'duckduckgo' or 'bing', queries that return 0 hits from the
# local Meilisearch index will be fetched from the chosen search engine via
# its public HTML endpoint (pure HTTP + cheerio, no headless browser).
#
# WARNING: Scraping search engines may violate their Terms of Service. Leave
# as 'none' unless you accept that risk for your use case.
SERP_BACKEND=none

# When true, SERP fallback hits are written back into the local Meilisearch
# index so future identical queries resolve locally.
SERP_INDEX_ON_FETCH=false